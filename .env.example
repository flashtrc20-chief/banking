# Database Configuration
# Get this from Neon Database connection string
# Format: postgresql://user:password@host.neon.tech/dbname
DATABASE_URL=postgresql://user:password@host.neon.tech/bolcrypto

# Server Configuration
NODE_ENV=production
PORT=3000

# Google Cloud Storage (if using cloud storage)
GCS_BUCKET_NAME=your-bucket-name
GCS_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# SendGrid Configuration (for email notifications)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@boltcrypto.com

# Stripe Configuration (for payment processing)
STRIPE_PUBLIC_KEY=pk_live_your_key
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# Blockchain RPC URLs (optional, can use defaults)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
BSC_RPC_URL=https://bsc-dataseed1.binance.org
SOL_RPC_URL=https://api.mainnet-beta.solana.com
TRON_RPC_URL=https://api.trongrid.io

# Application Configuration
VERCEL=true
VERCEL_ENV=production
REPLIT_CLUSTER=production

# Session Configuration
SESSION_SECRET=your-secure-random-session-secret
